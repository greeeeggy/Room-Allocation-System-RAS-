rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read their own profile; anyone logged in can read (for directory and notifications)
    match /users/{userId} {
      allow get, list: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Rooms: anyone logged in can read; mayors can update status and seed
    match /rooms/{roomId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mayor';
    }

    // Schedule blocks: mayors own their blocks
    // hasConflict updates are allowed for any authenticated user (conflict
    // flagging can affect the OTHER mayor's block, not just the actor's own).
    match /scheduleBlocks/{blockId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.mayorId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.mayorId == request.auth.uid
            || (request.resource.data.keys().hasOnly(['hasConflict'])));
      allow delete: if request.auth != null
        && resource.data.mayorId == request.auth.uid;
    }

    // Notifications: any authenticated user can create (conflict detection
    // writes notifications for other users' accounts).
    // Recipients can read and update (mark read).
    match /notifications/{notifId} {
      allow read, update: if request.auth != null
        && resource.data.recipientId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Mayor approvals: Read for validation (unauthenticated), management restricted to Council Presidents
    match /mayor_approvals/{approvalId} {
      allow read, write: if true;
      allow create, update: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'council_president'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department == request.resource.data.department;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'council_president'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.department == resource.data.department;
    }

    match /room_usage_logs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Lost & Found items — any auth'd user can read/create
    // Only the original poster can update (mark claimed) or delete
    match /lost_items/{itemId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.posterId == request.auth.uid;
    }

    // Messages — any auth'd user can read/create
    // Only the sender OR the lost item poster can delete
    match /lost_item_messages/{msgId} {
      allow read, create: if request.auth != null;
      allow delete: if request.auth != null
        && (resource.data.senderId == request.auth.uid
            || get(/databases/$(database)/documents/lost_items/$(resource.data.itemId)).data.posterId == request.auth.uid);
    }

  }
}
